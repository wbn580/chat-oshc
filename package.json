{
  "name": "chat-oshc-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create chat-oshc-leads",
    "d1:init": "wrangler d1 execute chat-oshc-leads --file=schema.sql --remote",
    "d1:init-local": "wrangler d1 execute chat-oshc-leads --file=schema.sql --local",
    "vectorize:create": "wrangler vectorize create kb-oshc --dimensions=1024 --metric=cosine"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260513.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.50.0"
  }
}
